# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# REDIS_URL: Optional Redis connection string (e.g., redis://127.0.0.1:6379) for 24h caching
# If not provided, the application will automatically fall back to high-performance in-memory TTL cache.
REDIS_URL=

# DISABLE_PUPPETEER: Optional. Set to "true" to disable National Library OPAC NLV lookups.
DISABLE_PUPPETEER=false

# PUPPETEER_EXECUTABLE_PATH: Optional. Path to local Chromium/Chrome executable.
# Essential for environments like Render, Docker, or local machine if Puppeteer's internal Chrome fails.
# Example on Linux/Render: /usr/bin/chromium-browser or /usr/bin/google-chrome
PUPPETEER_EXECUTABLE_PATH=

# PUPPETEER_WS_ENDPOINT: Optional. Remote Chrome/Chromium WebSocket endpoint (e.g., ws://... or wss://...).
# Highly recommended for serverless hosts (like Vercel) where local Chromium can't run because of function size limits.
# Use services like Browserless.io, ScrapingBee, or a dedicated Chrome service.
PUPPETEER_WS_ENDPOINT=

